---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sobre — B7KP" description="Desenvolvedor e criador do ZeroCharts.">
  <div class="max-w-2xl mx-auto px-4 pt-16 pb-20">
    <h1 class="text-3xl font-bold text-white mb-8">Sobre</h1>
    <div class="prose prose-invert prose-zinc max-w-none">
      <p>
        Olá, sou Bruno — desenvolvedor e fanático por gráficos e música.
        Criei o <a href="https://zerocharts.com.br">ZeroCharts</a> para que qualquer usuário do Last.fm
        possa montar seu próprio chart musical semanal personalizado.
      </p>
      <p>
        Tenho interesse em desenvolvimento web, visualização de dados e projetos interativos.
        Neste site compartilho updates dos meus projetos e ideias.
      </p>
      <h2>Contato</h2>
      <p>
        <a href="mailto:bruno7kp@gmail.com">bruno7kp@gmail.com</a>
      </p>
    </div>
  </div>
</Layout>
