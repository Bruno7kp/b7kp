---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog — B7KP" description="Posts sobre desenvolvimento, música e projetos.">
  <div class="max-w-4xl mx-auto px-4 pt-16 pb-20">
    <h1 class="text-3xl font-bold text-white mb-12">Blog</h1>
    <ul class="divide-y divide-zinc-800">
      {posts.map(post => (
        <li>
          <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`} class="group flex items-start justify-between py-5 gap-4">
            <div>
              <span class="text-white group-hover:text-zinc-300 transition-colors font-medium">{post.data.title}</span>
              <p class="text-sm text-zinc-500 mt-1">{post.data.description}</p>
            </div>
            <time class="text-xs text-zinc-500 shrink-0 pt-1">
              {post.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' })}
            </time>
          </a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
