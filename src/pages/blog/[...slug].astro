---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.id.replace(/\.mdx?$/, '') }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — B7KP`} description={post.data.description}>
  <article class="max-w-2xl mx-auto px-4 pt-16 pb-20">
    <header class="mb-10">
      <time class="text-xs text-zinc-500 uppercase tracking-widest">
        {post.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
      </time>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mt-3 leading-tight">{post.data.title}</h1>
      <p class="text-zinc-400 mt-3">{post.data.description}</p>
    </header>
    <div class="prose prose-invert prose-zinc max-w-none">
      <Content />
    </div>
  </article>
</Layout>
